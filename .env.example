# ============================================
# Support Ticket Management System
# Environment Variables Reference
# ============================================

# --- Backend (backend-api/.env) ---

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket_system

# Secret key for signing JWT tokens (must be at least 32 characters)
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long

# Port for the backend API server
PORT=3001

# --- Frontend (ui/.env) ---

# Backend API base URL (used by Vite/React app)
VITE_API_URL=http://localhost:3001/api
